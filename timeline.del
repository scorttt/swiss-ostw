        Clipping:       Clipping.DoNotClip,
        Spectators:     Spectators.VisibleNever);
    // left handle min timestamp
    CreateInWorldText(
        VisibleTo:      local.tl ? local : null, 
        Header:         FormattedFrameToSec(local.min_frame),
