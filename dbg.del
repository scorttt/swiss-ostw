import "main.del";

rule: "dbg"
Event.OngoingPlayer
if (player == host)
{
    ServerStats(player, 2);
    CreateHudText(host, null, <"Pos: <0>\nFacing: <1>\nRC: <2>", PositionOf(), Facing(), RayCastHitPosition(EyePos(), EyePos() + Facing() * 100, null, all, false)>, null, Location.Right, 0.5);
    CreateHudText(host, null, <"(<0>, <1>)\nsel_ctrl: <2>\nCF: <3>, MNF: <4>, MXF: <5>", CursorX(), CursorY(), sel_ctrl, frame, min_frame, max_frame>, null, Location.Right, 0.6);
}